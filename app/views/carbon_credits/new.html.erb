<h1 class="text-2xl font-bold text-ink">เพิ่ม Carbon Credit</h1>

<%= form_with url: carbon_credits_path, scope: :carbon_credit, class: "mt-6 max-w-md space-y-5" do |f| %>
  <div>
    <%= f.label :user_id, "ผู้ใช้", class: "mb-1 block font-medium text-ink" %>
    <%= f.select :user_id,
          @users.map { |u| [u.email, u.id] },
          { selected: @credit&.user_id, prompt: "— เลือกผู้ใช้ —" },
          required: true, class: "w-full rounded-lg border border-gray-300 px-4 py-2.5" %>
  </div>
  <div>
    <%= f.label :carbon_credit, "จำนวน Carbon Credit", class: "mb-1 block font-medium text-ink" %>
    <%= f.number_field :carbon_credit, value: @credit&.carbon_credit, required: true, step: 1, min: 1,
          class: "w-full rounded-lg border border-gray-300 px-4 py-2.5" %>
  </div>
  <div>
    <%= f.label :carbon_offset_source_id, "แหล่งออฟเซ็ต (ไม่บังคับ)", class: "mb-1 block font-medium text-ink" %>
    <%= f.select :carbon_offset_source_id,
          @sources.map { |s| [s.name_th.presence || s.name, s.id] },
          { selected: @credit&.carbon_offset_source_id, include_blank: "— ไม่ระบุ —" },
          class: "w-full rounded-lg border border-gray-300 px-4 py-2.5" %>
  </div>
  <%= f.submit "เพิ่ม", class: "rounded-lg bg-primary px-4 py-2 font-semibold text-white hover:bg-primary-dark cursor-pointer" %>
<% end %>
