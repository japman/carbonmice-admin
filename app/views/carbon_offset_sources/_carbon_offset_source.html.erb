<tr id="<%= dom_id(carbon_offset_source) %>" class="border-b border-gray-100">
  <td class="px-4 py-3 text-ink"><%= carbon_offset_source.name_th.presence || "—" %></td>
  <td class="px-4 py-3 font-mono text-xs"><%= carbon_offset_source.name %> 🔒</td>
  <td class="px-4 py-3 text-right whitespace-nowrap">
    <% if can?(:manage_master_data) %>
      <%= link_to "แก้ชื่อไทย", edit_carbon_offset_source_path(carbon_offset_source.id),
            data: { turbo_frame: "modal" }, class: "text-primary" %>
      <%= button_to "ลบ", carbon_offset_source_path(carbon_offset_source.id), method: :delete,
            form: { data: { turbo_confirm: "ลบแหล่ง #{carbon_offset_source.name}? (soft delete)" }, class: "inline" },
            class: "ml-3 cursor-pointer text-danger" %>
    <% end %>
  </td>
</tr>
